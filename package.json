{
  "name": "@sienklogic/plan-build-run",
  "version": "2.21.0",
  "description": "Plan it, Build it, Run it -- structured development workflow for Claude Code, OpenCode, Gemini and Codex",
  "bin": {
    "plan-build-run": "bin/install.js"
  },
  "files": [
    "bin",
    "plan-build-run",
    "scripts",
    "dashboard",
    "plugins/",
    "CLAUDE.md",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "plan-build-run",
    "pbr",
    "claude",
    "claude-code",
    "ai",
    "meta-prompting",
    "context-engineering",
    "spec-driven-development",
    "gemini",
    "gemini-cli",
    "codex",
    "codex-cli"
  ],
  "author": "SienkLogic",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SienkLogic/plan-build-run.git"
  },
  "homepage": "https://github.com/SienkLogic/plan-build-run",
  "bugs": {
    "url": "https://github.com/SienkLogic/plan-build-run/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "c8": "^11.0.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.0.0",
    "jest": "^29.0.0"
  },
  "scripts": {
    "dashboard:install": "cd dashboard && npm install && cd server && npm install",
    "dashboard": "node dashboard/bin/cli.cjs",
    "build:hooks": "node scripts/build-hooks.js",
    "prepublishOnly": "npm run build:hooks",
    "test": "node scripts/test-wrapper.js",
    "test:unit": "jest --selectProjects unit --forceExit",
    "test:integration": "jest --selectProjects integration --forceExit",
    "test:coverage": "jest --coverage --forceExit",
    "check-ci": "node scripts/check-ci.js",
    "test:dashboard": "cd dashboard && npx vitest run",
    "test:cjs": "jest --forceExit --testPathPattern=\"tests/(locked-file-update|concurrent-access|integration|local-llm)\"",
    "lint": "eslint plugins/pbr/scripts/ tests/",
    "sync:generate": "node scripts/generate-derivatives.js",
    "sync:verify": "node scripts/generate-derivatives.js --verify",
    "release": "node scripts/release.js",
    "release:dry": "node scripts/release.js --dry-run",
    "changelog": "node scripts/clean-changelog.js --write"
  }
}
