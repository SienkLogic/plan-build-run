{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Plan-Build-Run Config",
  "description": "Configuration schema for .planning/config.json",
  "type": "object",
  "properties": {
    "version": {
      "type": [
        "integer",
        "string"
      ],
      "enum": [
        1,
        2,
        "1",
        "2"
      ],
      "description": "Planning format version. v2 is current."
    },
    "schema_version": {
      "type": "integer",
      "enum": [
        1,
        2,
        3
      ],
      "description": "Config schema version for migration detection. Increment when config structure changes."
    },
    "context_strategy": {
      "type": "string",
      "enum": [
        "aggressive",
        "conservative",
        "balanced"
      ]
    },
    "mode": {
      "type": "string",
      "enum": [
        "interactive",
        "autonomous"
      ]
    },
    "depth": {
      "type": "string",
      "enum": [
        "quick",
        "standard",
        "comprehensive"
      ],
      "description": "Workflow depth: quick = budget mode (fewer spawns, skip optional stages), standard = balanced mode (conditional spawns), comprehensive = thorough mode (all spawns, current default)"
    },
    "session_phase_limit": {
      "type": "integer",
      "minimum": 0,
      "maximum": 20,
      "default": 3,
      "description": "Maximum phases to complete per session before suggesting a pause. 0 = disabled. Default scales with context_window_tokens: 3 at 200k, 6 at 500k, 8 at 1M."
    },
    "session_cycling": {
      "type": "string",
      "enum": [
        "tmux",
        "compact-first",
        "compact",
        "manual"
      ],
      "description": "How to cycle sessions when phase limit is reached. tmux = auto-cycle via tmux send-keys. compact-first = try /compact before cycling (recommended for 1M). compact = instruct user to compact+resume. manual = show banner only. Default: tmux if TMUX env detected, otherwise compact."
    },
    "context_window_tokens": {
      "type": "integer",
      "minimum": 100000,
      "maximum": 2000000,
      "default": 200000,
      "description": "Context window size in tokens for the active Claude model. Used to scale hook thresholds, agent checkpoint rules, and output budgets. Default 200000 matches Claude Sonnet/Haiku. Set to 1000000 for Claude models with 1M context."
    },
    "agent_checkpoint_pct": {
      "type": "integer",
      "minimum": 40,
      "maximum": 80,
      "default": 50,
      "description": "Context usage percentage at which agents should checkpoint and return output. Default 50 matches standard 200k models. Set to 65 for 1M-context models where agents can safely work longer before compacting."
    },
    "features": {
      "type": "object",
      "properties": {
        "structured_planning": {
          "type": "boolean"
        },
        "goal_verification": {
          "type": "boolean"
        },
        "integration_verification": {
          "type": "boolean"
        },
        "context_isolation": {
          "type": "boolean"
        },
        "atomic_commits": {
          "type": "boolean"
        },
        "session_persistence": {
          "type": "boolean"
        },
        "research_phase": {
          "type": "boolean"
        },
        "plan_checking": {
          "type": "boolean"
        },
        "tdd_mode": {
          "type": "boolean"
        },
        "status_line": {
          "type": "boolean"
        },
        "auto_continue": {
          "type": "boolean"
        },
        "auto_advance": {
          "type": "boolean"
        },
        "team_discussions": {
          "type": "boolean"
        },
        "inline_verify": {
          "type": "boolean"
        },
        "enhanced_session_start": {
          "type": "boolean",
          "default": true,
          "description": "Enable enhanced SessionStart briefing with structured context injection (~500 tokens)."
        },
        "context_quality_scoring": {
          "type": "boolean",
          "default": true,
          "description": "Enable context quality scoring to track signal-to-noise ratio."
        },
        "skip_rag": {
          "type": "boolean",
          "default": false,
          "description": "Enable Skip-RAG pattern: load entire codebase into context for small projects."
        },
        "zero_friction_quick": {
          "type": "boolean",
          "default": true,
          "description": "Enable zero-friction quick task mode: skip pre-execution ceremony, generate artifacts post-hoc."
        },
        "post_hoc_artifacts": {
          "type": "boolean",
          "default": true,
          "description": "Enable post-hoc artifact generation: SUMMARY.md auto-generated from git history after execution."
        },
        "inline_simple_tasks": {
          "type": "boolean",
          "default": true,
          "description": "Enable inline execution for simple tasks (<5 files, <50 lines). When false, all tasks delegate to subagents."
        },
        "rich_agent_prompts": {
          "type": "boolean",
          "default": true,
          "description": "Enable enriched agent prompts with full project context when context budget allows."
        },
        "multi_phase_awareness": {
          "type": "boolean",
          "default": true,
          "description": "Enable orchestrator to hold multiple phase plans simultaneously in context."
        },
        "decision_journal": {
          "type": "boolean",
          "default": true,
          "description": "Enable decision journal — records WHY decisions were made in .planning/decisions/."
        },
        "negative_knowledge": {
          "type": "boolean",
          "default": true,
          "description": "Enable negative knowledge tracking — records what failed and why in .planning/negative-knowledge/."
        },
        "living_requirements": {
          "type": "boolean",
          "default": true,
          "description": "Enable living requirements — auto-update requirement status as phases complete."
        },
        "trust_tracking": {
          "type": "boolean",
          "default": true,
          "description": "Enable trust score tracking per agent type and task category. Data stored in .planning/trust/agent-scores.json."
        },
        "confidence_calibration": {
          "type": "boolean",
          "default": true,
          "description": "Enable confidence scores on deliverables based on historical agent accuracy."
        },
        "natural_language_routing": {
          "type": "boolean",
          "default": true,
          "description": "Enable natural language intent detection and routing in /pbr:do. When false, /pbr:do uses static keyword matching only."
        },
        "adaptive_ceremony": {
          "type": "boolean",
          "default": true,
          "description": "Enable risk-based ceremony adjustment. When false, all tasks use standard ceremony regardless of risk level."
        },
        "graduated_verification": {
          "type": "boolean",
          "default": true,
          "description": "Enable trust-based graduated verification depth (light/standard/thorough)."
        },
        "self_verification": {
          "type": "boolean",
          "default": true,
          "description": "Enable executor self-verification before presenting output."
        },
        "agent_feedback_loop": {
          "type": "boolean",
          "default": true,
          "description": "Enable agent feedback loop — verification results feed back into executor agent prompts."
        },
        "session_metrics": {
          "type": "boolean",
          "default": true,
          "description": "Enable session metrics dashboard at session end showing time, agents, commits, compliance."
        },
        "convention_memory": {
          "type": "boolean",
          "default": true,
          "description": "Enable auto-detection and storage of project conventions (naming, testing, architecture patterns) in .planning/conventions/."
        },
        "mental_model_snapshots": {
          "type": "boolean",
          "default": true,
          "description": "Enable mental model snapshots at session end capturing working context (files, decisions, thinking) for instant resume."
        },
        "smart_next_task": {
          "type": "boolean",
          "default": true,
          "description": "Enable smart next-task suggestion using dependency graph analysis in auto-continue."
        },
        "dependency_break_detection": {
          "type": "boolean",
          "default": true,
          "description": "Enable dependency break detection — warn when upstream changes invalidate downstream plans."
        },
        "pre_research": {
          "type": "boolean",
          "default": true,
          "description": "Enable pre-research for upcoming phases spawned at 70%+ phase completion."
        },
        "pattern_routing": {
          "type": "boolean",
          "default": true,
          "description": "Enable pattern-based auto-routing — file modification patterns trigger specialized agents."
        },
        "tech_debt_surfacing": {
          "type": "boolean",
          "default": true,
          "description": "Enable continuous tech debt surfacing in status dashboard."
        }
      },
      "additionalProperties": false
    },
    "autonomy": {
      "type": "object",
      "properties": {
        "level": {
          "type": "string",
          "enum": [
            "supervised",
            "guided",
            "collaborative",
            "adaptive"
          ],
          "default": "supervised",
          "description": "Progressive autonomy level. supervised=human approves all, guided=AI acts/human reviews async, collaborative=AI handles routine/escalates novel, adaptive=AI adjusts own autonomy per task confidence."
        }
      },
      "additionalProperties": false
    },
    "models": {
      "type": "object",
      "properties": {
        "researcher": {
          "type": "string"
        },
        "planner": {
          "type": "string"
        },
        "executor": {
          "type": "string"
        },
        "verifier": {
          "type": "string"
        },
        "integration_checker": {
          "type": "string"
        },
        "debugger": {
          "type": "string"
        },
        "mapper": {
          "type": "string"
        },
        "synthesizer": {
          "type": "string"
        },
        "complexity_map": {
          "type": "object",
          "properties": {
            "simple": {
              "type": "string",
              "default": "haiku"
            },
            "medium": {
              "type": "string",
              "default": "sonnet"
            },
            "complex": {
              "type": "string",
              "default": "inherit"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "model_profiles": {
      "type": "object",
      "description": "User-defined custom model profiles. Each key is a profile name; value is an object mapping agent names to model strings (sonnet, opus, haiku, inherit). Partial profiles allowed — omitted agents fall back to the active profile defaults.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "researcher": {
            "type": "string"
          },
          "planner": {
            "type": "string"
          },
          "executor": {
            "type": "string"
          },
          "verifier": {
            "type": "string"
          },
          "integration_checker": {
            "type": "string"
          },
          "debugger": {
            "type": "string"
          },
          "mapper": {
            "type": "string"
          },
          "synthesizer": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "parallelization": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "plan_level": {
          "type": "boolean"
        },
        "task_level": {
          "type": "boolean"
        },
        "max_concurrent_agents": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "min_plans_for_parallel": {
          "type": "integer",
          "minimum": 1
        },
        "use_teams": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "teams": {
      "type": "object",
      "properties": {
        "planning_roles": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "architect",
            "security-reviewer",
            "test-designer"
          ]
        },
        "review_roles": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "functional-reviewer",
            "security-auditor",
            "performance-analyst"
          ]
        },
        "synthesis_model": {
          "type": "string",
          "default": "sonnet",
          "description": "Model used for the synthesizer agent that combines team outputs"
        },
        "coordination": {
          "type": "string",
          "enum": [
            "file-based",
            "sequential"
          ],
          "default": "file-based",
          "description": "How team members coordinate: file-based (parallel writes to separate files) or sequential"
        }
      },
      "additionalProperties": false
    },
    "planning": {
      "type": "object",
      "properties": {
        "commit_docs": {
          "type": "boolean"
        },
        "max_tasks_per_plan": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        },
        "search_gitignored": {
          "type": "boolean"
        },
        "multi_phase": {
          "type": "boolean",
          "default": false,
          "description": "When true, enables --through flag for multi-phase planning in a single planner session."
        }
      },
      "additionalProperties": false
    },
    "git": {
      "type": "object",
      "properties": {
        "branching": {
          "type": "string",
          "enum": [
            "none",
            "phase",
            "milestone",
            "disabled"
          ]
        },
        "commit_format": {
          "type": "string"
        },
        "phase_branch_template": {
          "type": "string"
        },
        "milestone_branch_template": {
          "type": "string"
        },
        "mode": {
          "type": "string",
          "enum": [
            "enabled",
            "disabled"
          ]
        }
      },
      "additionalProperties": false
    },
    "gates": {
      "type": "object",
      "properties": {
        "confirm_project": {
          "type": "boolean"
        },
        "confirm_roadmap": {
          "type": "boolean"
        },
        "confirm_plan": {
          "type": "boolean"
        },
        "confirm_execute": {
          "type": "boolean"
        },
        "confirm_transition": {
          "type": "boolean"
        },
        "issues_review": {
          "type": "boolean"
        },
        "confirm_research": {
          "type": "boolean"
        },
        "confirm_seeds": {
          "type": "boolean"
        },
        "confirm_deferred": {
          "type": "boolean"
        },
        "confirm_commit_docs": {
          "type": "boolean"
        },
        "auto_checkpoints": {
          "type": "boolean",
          "default": false,
          "description": "When true, executor auto-resolves checkpoint:human-verify tasks by running automated verify and approving if it passes. checkpoint:decision and checkpoint:human-action always require human input."
        },
        "checkpoint_auto_resolve": {
          "type": "string",
          "enum": [
            "none",
            "verify-only",
            "verify-and-decision",
            "all"
          ],
          "default": "none",
          "description": "Which checkpoint types the executor auto-resolves. verify-only = auto-resolve human-verify checkpoints. verify-and-decision = auto-resolve both. all = auto-resolve everything (not recommended). none = always ask. Note: human-action checkpoints are NEVER auto-resolved regardless of this setting."
        }
      },
      "additionalProperties": false
    },
    "safety": {
      "type": "object",
      "properties": {
        "always_confirm_destructive": {
          "type": "boolean"
        },
        "always_confirm_external_services": {
          "type": "boolean"
        },
        "enforce_phase_boundaries": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "timeouts": {
      "type": "object",
      "properties": {
        "task_default_ms": {
          "type": "integer",
          "minimum": 30000,
          "description": "Default timeout per task in milliseconds (default: 300000 = 5 min)"
        },
        "build_max_ms": {
          "type": "integer",
          "minimum": 60000,
          "description": "Maximum time for entire build command in milliseconds"
        },
        "verify_max_ms": {
          "type": "integer",
          "minimum": 30000,
          "description": "Maximum time for verification in milliseconds"
        }
      },
      "additionalProperties": false
    },
    "hooks": {
      "type": "object",
      "properties": {
        "autoFormat": {
          "type": "boolean"
        },
        "typeCheck": {
          "type": "boolean"
        },
        "detectConsoleLogs": {
          "type": "boolean"
        },
        "blockDocSprawl": {
          "type": "boolean"
        },
        "compactThreshold": {
          "type": "integer",
          "minimum": 10,
          "maximum": 200
        }
      },
      "additionalProperties": false
    },
    "prd": {
      "type": "object",
      "description": "Settings for PRD import via /pbr:import --prd.",
      "properties": {
        "auto_extract": {
          "type": "boolean",
          "default": false,
          "description": "When true, skip the confirmation gate during PRD import and write files immediately. Default: false (confirm-first)."
        }
      },
      "additionalProperties": false
    },
    "depth_profiles": {
      "type": "object",
      "description": "Depth profile overrides. Each profile maps depth value to effective feature/gate settings.",
      "properties": {
        "quick": {
          "type": "object",
          "properties": {
            "features.research_phase": {
              "type": "boolean"
            },
            "features.plan_checking": {
              "type": "boolean"
            },
            "features.goal_verification": {
              "type": "boolean"
            },
            "features.inline_verify": {
              "type": "boolean"
            },
            "features.post_hoc_artifacts": {
              "type": "boolean"
            },
            "features.agent_feedback_loop": {
              "type": "boolean"
            },
            "features.session_metrics": {
              "type": "boolean"
            },
            "scan.mapper_count": {
              "type": "integer",
              "minimum": 1,
              "maximum": 4
            },
            "scan.mapper_areas": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "debug.max_hypothesis_rounds": {
              "type": "integer",
              "minimum": 1,
              "maximum": 20
            }
          },
          "additionalProperties": false
        },
        "standard": {
          "type": "object",
          "properties": {
            "features.research_phase": {
              "type": "boolean"
            },
            "features.plan_checking": {
              "type": "boolean"
            },
            "features.goal_verification": {
              "type": "boolean"
            },
            "features.inline_verify": {
              "type": "boolean"
            },
            "features.post_hoc_artifacts": {
              "type": "boolean"
            },
            "features.agent_feedback_loop": {
              "type": "boolean"
            },
            "features.session_metrics": {
              "type": "boolean"
            },
            "scan.mapper_count": {
              "type": "integer",
              "minimum": 1,
              "maximum": 4
            },
            "scan.mapper_areas": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "debug.max_hypothesis_rounds": {
              "type": "integer",
              "minimum": 1,
              "maximum": 20
            }
          },
          "additionalProperties": false
        },
        "comprehensive": {
          "type": "object",
          "properties": {
            "features.research_phase": {
              "type": "boolean"
            },
            "features.plan_checking": {
              "type": "boolean"
            },
            "features.goal_verification": {
              "type": "boolean"
            },
            "features.inline_verify": {
              "type": "boolean"
            },
            "features.post_hoc_artifacts": {
              "type": "boolean"
            },
            "features.agent_feedback_loop": {
              "type": "boolean"
            },
            "features.session_metrics": {
              "type": "boolean"
            },
            "scan.mapper_count": {
              "type": "integer",
              "minimum": 1,
              "maximum": 4
            },
            "scan.mapper_areas": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "debug.max_hypothesis_rounds": {
              "type": "integer",
              "minimum": 1,
              "maximum": 20
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "debug": {
      "type": "object",
      "properties": {
        "max_hypothesis_rounds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20
        }
      },
      "additionalProperties": false
    },
    "developer_profile": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable developer profiling. When true, /pbr:profile-user skill is available to generate behavioral profiles from session history."
        },
        "inject_prompts": {
          "type": "boolean",
          "default": false,
          "description": "When true, inject USER-PROFILE.md summary into agent prompts for personalized communication."
        }
      },
      "additionalProperties": false
    },
    "spinner_tips": {
      "type": "object",
      "description": "Custom spinner tips shown during agent execution (Claude Code 2.1.45+)",
      "properties": {
        "tips": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Array of custom tip strings to display in the spinner"
        },
        "exclude_defaults": {
          "type": "boolean",
          "description": "When true, only show custom tips (no default Claude Code tips)"
        }
      },
      "additionalProperties": false
    },
    "dashboard": {
      "type": "object",
      "properties": {
        "auto_launch": {
          "type": "boolean"
        },
        "port": {
          "type": "integer",
          "minimum": 1024,
          "maximum": 65535
        }
      },
      "additionalProperties": false
    },
    "status_line": {
      "type": "object",
      "properties": {
        "sections": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "phase",
              "plan",
              "status",
              "context"
            ]
          }
        },
        "brand_text": {
          "type": "string"
        },
        "max_status_length": {
          "type": "integer",
          "minimum": 10,
          "maximum": 200
        },
        "context_bar": {
          "type": "object",
          "properties": {
            "width": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            },
            "thresholds": {
              "type": "object",
              "properties": {
                "green": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 100
                },
                "yellow": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 100
                }
              },
              "additionalProperties": false
            },
            "chars": {
              "type": "object",
              "properties": {
                "filled": {
                  "type": "string"
                },
                "empty": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "workflow": {
      "type": "object",
      "properties": {
        "enforce_pbr_skills": {
          "type": "string",
          "enum": [
            "advisory",
            "block",
            "off"
          ],
          "default": "advisory",
          "description": "Enforcement level for PBR workflow compliance"
        },
        "inline_execution": {
          "type": "boolean",
          "default": false,
          "description": "When true, trivial plans (simple complexity, few tasks) execute inline without spawning a subagent."
        },
        "inline_max_tasks": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5,
          "default": 2,
          "description": "Maximum task count for inline execution eligibility. Plans with more tasks spawn a subagent."
        },
        "inline_context_cap_pct": {
          "type": "integer",
          "minimum": 10,
          "maximum": 80,
          "default": 40,
          "description": "Context usage percentage cap for inline execution. Above this, always spawn a subagent."
        },
        "phase_boundary_clear": {
          "type": "string",
          "enum": [
            "recommend",
            "enforce",
            "off"
          ],
          "default": "off",
          "description": "Whether to recommend or enforce /clear at phase boundaries. recommend = advisory message, enforce = block continuation without /clear, off = no action."
        },
        "autonomous": {
          "type": "boolean",
          "default": false,
          "description": "When true, enables /pbr:autonomous skill for hands-free multi-phase execution."
        },
        "speculative_planning": {
          "type": "boolean",
          "default": false,
          "description": "When true, orchestrator spawns planner for phase N+1 while executor runs phase N (independent phases only)."
        },
        "phase_replay": {
          "type": "boolean",
          "default": false,
          "description": "When true, failed verification triggers replay with enriched context (original plan + SUMMARY + VERIFICATION failures + diffs)."
        },
        "inline_max_files": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20,
          "default": 5,
          "description": "Maximum files a task can touch to be eligible for inline execution."
        },
        "inline_max_lines": {
          "type": "integer",
          "minimum": 10,
          "maximum": 500,
          "default": 50,
          "description": "Maximum estimated lines of change for inline execution eligibility."
        },
        "max_phases_in_context": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10,
          "default": 3,
          "description": "Maximum number of phase plans the orchestrator holds simultaneously."
        }
      },
      "additionalProperties": false
    },
    "hook_server": {
      "type": "object",
      "description": "Persistent HTTP hook server settings. When enabled, hooks POST to the server instead of spawning per-hook processes.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "When true, hook-server-client.js routes hook events to the persistent hook-server.js process."
        },
        "port": {
          "type": "integer",
          "minimum": 1024,
          "maximum": 65535,
          "default": 19836,
          "description": "TCP port the hook server listens on (127.0.0.1 only)."
        },
        "event_log": {
          "type": "boolean",
          "default": true,
          "description": "When true, all hook events are appended to .planning/.hook-events.jsonl."
        }
      },
      "additionalProperties": false
    },
    "local_llm": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "provider": {
          "type": "string",
          "enum": [
            "ollama"
          ]
        },
        "endpoint": {
          "type": "string",
          "format": "uri"
        },
        "model": {
          "type": "string"
        },
        "timeout_ms": {
          "type": "integer",
          "minimum": 500
        },
        "max_retries": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3
        },
        "fallback": {
          "type": "string",
          "enum": [
            "frontier",
            "skip"
          ]
        },
        "routing_strategy": {
          "type": "string",
          "enum": [
            "local_first",
            "frontier_first"
          ]
        },
        "features": {
          "type": "object",
          "properties": {
            "artifact_classification": {
              "type": "boolean"
            },
            "task_validation": {
              "type": "boolean"
            },
            "plan_adequacy": {
              "type": "boolean"
            },
            "gap_detection": {
              "type": "boolean"
            },
            "context_summarization": {
              "type": "boolean"
            },
            "source_scoring": {
              "type": "boolean"
            },
            "commit_classification": {
              "type": "boolean"
            },
            "test_triage": {
              "type": "boolean"
            },
            "file_intent_classification": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        "metrics": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "log_file": {
              "type": "string"
            },
            "show_session_summary": {
              "type": "boolean"
            },
            "frontier_token_rate": {
              "type": "number",
              "minimum": 0
            }
          },
          "additionalProperties": false
        },
        "advanced": {
          "type": "object",
          "properties": {
            "confidence_threshold": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "max_input_tokens": {
              "type": "integer",
              "minimum": 100
            },
            "keep_alive": {
              "type": "string"
            },
            "num_ctx": {
              "type": "integer",
              "minimum": 512
            },
            "disable_after_failures": {
              "type": "integer",
              "minimum": 1
            },
            "shadow_mode": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "intel": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable persistent codebase intelligence system. When false, all intel features are no-ops."
        },
        "auto_update": {
          "type": "boolean",
          "default": false,
          "description": "When true, PostToolUse hooks queue intel updates on code file changes."
        },
        "inject_on_start": {
          "type": "boolean",
          "default": false,
          "description": "When true, SessionStart hook injects .planning/intel/arch.md summary into session context."
        }
      },
      "additionalProperties": false
    },
    "context_ledger": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable context composition tracking. When true, track-context-budget.js records file path, timestamp, tokens, and phase per Read."
        },
        "stale_after_minutes": {
          "type": "integer",
          "minimum": 5,
          "maximum": 1440,
          "default": 60,
          "description": "Minutes after which a context read is considered stale for compact suggestions."
        }
      },
      "additionalProperties": false
    },
    "learnings": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable cross-phase knowledge transfer. When true, executor writes LEARNINGS.md and planner reads prior learnings."
        },
        "read_depth": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20,
          "default": 3,
          "description": "Number of prior phases' LEARNINGS.md files the planner reads for context."
        },
        "cross_project_knowledge": {
          "type": "boolean",
          "default": false,
          "description": "When true, learnings marked cross_project: true in LEARNINGS.md are copied to ~/.claude/pbr-knowledge/ for use across projects."
        }
      },
      "additionalProperties": false
    },
    "verification": {
      "type": "object",
      "properties": {
        "confidence_gate": {
          "type": "boolean",
          "default": false,
          "description": "When true, enable confidence-gated verification skip. If executor reports 100% must-have completion with commit SHAs AND tests pass, auto-mark verified."
        },
        "confidence_threshold": {
          "type": "number",
          "minimum": 0.5,
          "maximum": 1,
          "default": 1,
          "description": "Minimum completion confidence (0.5-1.0) required to skip verification. 1.0 means 100% must-haves must pass."
        }
      },
      "additionalProperties": false
    },
    "context_budget": {
      "type": "object",
      "properties": {
        "threshold_curve": {
          "type": "string",
          "enum": [
            "linear",
            "adaptive"
          ],
          "default": "linear",
          "description": "Warning threshold scaling. linear = current fixed percentages (50/70/85). adaptive = non-linear scaling that shifts thresholds up at 1M context (60/75/85)."
        }
      },
      "additionalProperties": false
    },
    "ui": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable UI design pipeline. When true, /pbr:ui-phase and /pbr:ui-review skills are available. Auto-detected for frontend projects unless explicitly set."
        }
      },
      "additionalProperties": false
    },
    "worktree": {
      "type": "object",
      "description": "Settings for agents running with isolation: worktree.",
      "properties": {
        "sparse_paths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Glob patterns for sparse checkout in worktrees. When non-empty, worktree agents only check out matching paths (e.g. [\"src/**\", \"package.json\", \".planning/**\"]). Empty array = full checkout (default)."
        }
      },
      "additionalProperties": false
    },
    "ceremony_level": {
      "type": "string",
      "enum": [
        "auto",
        "low",
        "medium",
        "high"
      ],
      "default": "auto",
      "description": "Override ceremony level. auto = risk-classifier decides. low = inline execution, no plan. medium = lightweight plan. high = full plan-build-verify cycle."
    },
    "skip_rag_max_lines": {
      "type": "integer",
      "minimum": 1000,
      "maximum": 500000,
      "default": 50000,
      "description": "Maximum project lines for Skip-RAG eligibility. Projects under this threshold can load entire codebase."
    },
    "orchestrator_budget_pct": {
      "type": "integer",
      "minimum": 15,
      "maximum": 50,
      "default": 25,
      "description": "Target orchestrator context budget as percentage of total window. Range 15-50%. Higher values enable more inline work."
    }
  },
  "additionalProperties": false
}
